{
  "manifest_version": 3,
  "name": "Docs Session Memory",
  "version": "0.1",
  "description": "project-level session memory for Google Docs",
  "permissions": ["tabs", "storage", "tabGroups", "activeTab", "scripting", "identity"],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://drive.google.com/*"
  ],
  "oauth2": {
    "client_id": "YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.readonly"]
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Docs Session Memory",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/*","https://drive.google.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}